<mvc:View
    controllerName="net.bansemir.profile.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    displayBlock="true">
    <Page showHeader="false" enableScrolling="false">
        <f:ShellBar
            title="{config>/owner/name}"
            secondTitle="{i18n>hero.role}"
            showNavButton="false">
            <f:additionalContent>
                <OverflowToolbarButton
                    id="themeToggle"
                    icon="sap-icon://light-mode"
                    type="Transparent"
                    press=".onThemeToggle"
                    tooltip="{i18n>nav.themeToggle}" />
                <OverflowToolbarButton
                    icon="sap-icon://globe"
                    type="Transparent"
                    press=".onLanguageToggle"
                    tooltip="{i18n>nav.langSwitch}" />
                <OverflowToolbarButton
                    icon="sap-icon://source-code"
                    type="Transparent"
                    tooltip="GitHub"
                    press=".onOpenGitHub" />
            </f:additionalContent>
        </f:ShellBar>
        <App id="app" />
        <footer>
            <OverflowToolbar>
                <Link text="{i18n>footer.imprint}" href="../../legal/impressum.html" />
                <ToolbarSeparator />
                <Link text="{i18n>footer.privacy}" href="../../legal/datenschutz.html" />
                <ToolbarSeparator />
                <Link text="GitHub" href="https://github.com/bansemir/bansemir.net" target="_blank" />
                <ToolbarSeparator />
                <Link text="LinkedIn" href="https://linkedin.com/in/carsten-bansemir" target="_blank" />
                <ToolbarSpacer />
                <Text text="{i18n>footer.copyright}" />
                <ToolbarSeparator />
                <Text text="{i18n>footer.builtWith}" />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>
