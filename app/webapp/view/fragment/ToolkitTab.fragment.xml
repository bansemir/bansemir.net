<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    core:require="{ formatter: 'net/bansemir/profile/model/formatter' }">

    <VBox>
        <HBox justifyContent="SpaceAround" wrap="Wrap" class="sapUiMediumMarginBottom">
            <GenericTile header="{i18n>toolkit.stats.lines}" frameType="OneByOne">
                <TileContent>
                    <NumericContent value="{toolkit>/toolkit/totalLines}" scale="" withMargin="false" />
                </TileContent>
            </GenericTile>
            <GenericTile header="{i18n>toolkit.stats.rules}" frameType="OneByOne">
                <TileContent>
                    <NumericContent value="{toolkit>/toolkit/totalRules}" withMargin="false" />
                </TileContent>
            </GenericTile>
            <GenericTile header="{i18n>toolkit.stats.tests}" frameType="OneByOne">
                <TileContent>
                    <NumericContent value="{toolkit>/toolkit/totalTests}" withMargin="false" />
                </TileContent>
            </GenericTile>
            <GenericTile header="{i18n>toolkit.stats.domains}" frameType="OneByOne">
                <TileContent>
                    <NumericContent value="{toolkit>/toolkit/totalDomains}" withMargin="false" />
                </TileContent>
            </GenericTile>
        </HBox>

        <IconTabBar id="toolkitTabBar" expandable="false" class="sapUiNoContentPadding">
            <items>
                <IconTabFilter text="{i18n>toolkit.fieldChange.title}" key="field-change">
                    <VBox class="sapUiSmallMargin">
                        <Text text="{i18n>toolkit.fieldChange.description}" />
                    </VBox>
                </IconTabFilter>
                <IconTabFilter text="{i18n>toolkit.codeReview.title}" key="code-review">
                    <VBox class="sapUiSmallMargin">
                        <Text text="{i18n>toolkit.codeReview.description}" />
                    </VBox>
                </IconTabFilter>
                <IconTabFilter text="{i18n>toolkit.rapGenerator.title}" key="rap-generator">
                    <VBox class="sapUiSmallMargin">
                        <Text text="{i18n>toolkit.rapGenerator.description}" />
                    </VBox>
                </IconTabFilter>
                <IconTabFilter text="{i18n>toolkit.ticketAnalysis.title}" key="ticket-analysis">
                    <VBox class="sapUiSmallMargin">
                        <Text text="{i18n>toolkit.ticketAnalysis.description}" />
                    </VBox>
                </IconTabFilter>
            </items>
        </IconTabBar>

        <VBox class="sapUiMediumMarginTop" alignItems="Center">
            <Text text="{i18n>toolkit.result}" class="sapUiSmallMarginBottom" />
            <Button text="{i18n>toolkit.cta}" type="Emphasized" press=".onOpenCalendly" />
        </VBox>
    </VBox>

</core:FragmentDefinition>
