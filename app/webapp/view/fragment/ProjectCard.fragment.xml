<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    core:require="{ formatter: 'net/bansemir/profile/model/formatter' }">
    <List
        id="projectList"
        items="{path: 'projects>/projects', sorter: {path: 'sortOrder'}}">
        <headerToolbar>
            <OverflowToolbar>
                <Title text="{i18n>projects.heading}" />
            </OverflowToolbar>
        </headerToolbar>
        <ObjectListItem
            title="{path: 'projects>role', formatter: 'formatter.formatLocalized'}"
            number="{projects>period}"
            type="Navigation"
            press=".onNavToProject">
            <attributes>
                <ObjectAttribute
                    title="{i18n>projects.client}"
                    text="{path: 'projects>client', formatter: 'formatter.formatLocalized'}" />
                <ObjectAttribute text="{projects>company}" />
            </attributes>
        </ObjectListItem>
    </List>
</core:FragmentDefinition>
